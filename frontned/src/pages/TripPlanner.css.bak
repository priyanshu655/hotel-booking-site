/* ═══════════════════════════════════════════════════════════════════
   PLANORA — NATURE / DARK FOREST THEME
   Inspired by: deep woodland, moss, dusk light through canopy
   Palette: near-black soil · deep forest greens · warm amber dusk ·
            sage · cream parchment · earthy terracotta
   Fonts: Canela / DM Serif Display · Satoshi / Cabinet Grotesk
   ═══════════════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Jost:wght@300;400;500;600&family=Playfair+Display:ital,wght@1,400;1,500&display=swap');

/* ── Design Tokens ── */
:root {
  /* Core palette */
  --soil:        #0d110e;   /* deepest background */
  --bark:        #141a15;   /* card backgrounds */
  --moss-dark:   #1c2a1e;   /* elevated surfaces */
  --moss:        #243527;   /* borders, dividers */
  --canopy:      #2e4a32;   /* active states */
  --fern:        #3d6642;   /* secondary accent */
  --sage:        #6b9e6e;   /* muted text accent */
  --meadow:      #8ec490;   /* primary text accent */
  --mist:        #b8d9b9;   /* light accent */
  --dew:         #ddeedd;   /* near-white */

  /* Warm accents — golden hour light */
  --amber:       #d4893a;
  --amber-light: #f0b060;
  --amber-glow:  #f8c87855;
  --terracotta:  #c4623a;
  --cream:       #f5ede0;
  --parchment:   #e8dcc8;

  /* Utility */
  --text-primary:   #e8edd8;
  --text-secondary: #9aaa8a;
  --text-muted:     #5a6e56;
  --text-faint:     #3a4e38;

  --ease-out:    cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
}

/* ── Reset ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }

body {
  background: var(--soil);
  color: var(--text-primary);
  font-family: 'Jost', sans-serif;
  overflow-x: hidden;
}

/* ── Scrollbar ── */
::-webkit-scrollbar { width: 3px; }
::-webkit-scrollbar-track { background: var(--soil); }
::-webkit-scrollbar-thumb { background: var(--moss); border-radius: 2px; }

/* ════════════════════════════════
   PAGE SHELL
   ════════════════════════════════ */
.tp-page {
  min-height: 100vh;
  background: var(--soil);
  position: relative;
}

/* ── Organic noise texture overlay ── */
.tp-page::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.035;
  background-image:
    url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px 200px;
  mix-blend-mode: overlay;
}

/* ── Floating botanical orbs ── */
.tp-particles {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.tp-particle {
  position: absolute;
  border-radius: 50%;
  filter: blur(70px);
  opacity: 0.5;
}

@keyframes tpFloat0 {
  0%,100% { transform: translate(0,0) scale(1); }
  50% { transform: translate(40px, -50px) scale(1.12); }
}
@keyframes tpFloat1 {
  0%,100% { transform: translate(0,0) scale(1); }
  50% { transform: translate(-45px, 30px) scale(0.9); }
}
@keyframes tpFloat2 {
  0%,100% { transform: translate(0,0) scale(1); }
  33% { transform: translate(25px, 40px) scale(1.08); }
  66% { transform: translate(-20px, -25px) scale(0.95); }
}

/* ════════════════════════════════
   NAVBAR
   ════════════════════════════════ */
.tp-nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  padding: 0 52px;
  transition: all 0.5s var(--ease-out);
}

.tp-nav.scrolled {
  background: rgba(13, 17, 14, 0.88);
  backdrop-filter: blur(28px) saturate(1.4);
  border-bottom: 1px solid var(--moss);
  box-shadow: 0 4px 40px rgba(0, 0, 0, 0.4);
}

.tp-nav-inner {
  max-width: 1280px;
  margin: 0 auto;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tp-nav-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
}

.tp-nav-brand-mark {
  width: 38px; height: 38px;
  background: linear-gradient(135deg, var(--fern), var(--canopy));
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'DM Serif Display', serif;
  font-size: 20px;
  color: var(--dew);
  box-shadow: 0 4px 20px rgba(61,102,66,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
  border: 1px solid var(--fern);
}

.tp-nav-brand-name {
  font-family: 'DM Serif Display', serif;
  font-size: 22px;
  color: var(--dew);
  letter-spacing: 1px;
  font-style: italic;
}

.tp-nav-links {
  display: flex;
  align-items: center;
  gap: 2px;
}

.tp-nav-link {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 8px 18px;
  border-radius: 40px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-secondary);
  text-decoration: none;
  letter-spacing: 0.3px;
  transition: all 0.3s;
  white-space: nowrap;
}

.tp-nav-link:hover {
  color: var(--dew);
  background: var(--moss-dark);
}

.tp-nav-link.active {
  color: var(--meadow);
  background: rgba(61,102,66,0.2);
}

.tp-nav-user {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 16px;
  background: none;
  border: 1px solid var(--moss);
  border-radius: 40px;
  color: var(--text-secondary);
  font-size: 13px;
  cursor: pointer;
  transition: all 0.25s;
  font-family: 'Jost', sans-serif;
}

.tp-nav-user:hover {
  background: var(--moss-dark);
  color: var(--dew);
  border-color: var(--fern);
}

.tp-nav-avatar {
  width: 26px; height: 26px;
  background: linear-gradient(135deg, var(--canopy), var(--fern));
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: var(--dew);
  font-size: 11px;
  font-weight: 600;
  border: 1px solid var(--fern);
}

/* ════════════════════════════════
   CONTENT
   ════════════════════════════════ */
.tp-content {
  position: relative;
  z-index: 1;
  padding-top: 72px;
  max-width: 900px;
  margin: 0 auto;
  padding-left: 28px;
  padding-right: 28px;
  padding-bottom: 120px;
  min-height: 100vh;
}

/* ════════════════════════════════
   HERO / START AREA
   ════════════════════════════════ */
.tp-start-area {
  padding: 80px 0 60px;
  text-align: center;
}

/* Large botanical illustration ring */
.tp-hero-ring {
  position: relative;
  width: 180px; height: 180px;
  margin: 0 auto 48px;
}

.tp-hero-ring-outer {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1px solid var(--moss);
  animation: ringRotate 20s linear infinite;
}

@keyframes ringRotate {
  to { transform: rotate(360deg); }
}

.tp-hero-ring-inner {
  position: absolute;
  inset: 20px;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%, var(--canopy), var(--moss-dark) 70%);
  display: flex; align-items: center; justify-content: center;
  font-size: 56px;
  border: 1px solid var(--fern);
  box-shadow:
    0 0 60px rgba(46,74,50,0.5),
    0 0 120px rgba(46,74,50,0.2),
    inset 0 2px 0 rgba(255,255,255,0.05);
}

.tp-hero-ring-dot {
  position: absolute;
  width: 8px; height: 8px;
  background: var(--amber);
  border-radius: 50%;
  top: 4px; left: 50%;
  transform: translateX(-50%);
  box-shadow: 0 0 12px var(--amber);
}

/* Eyebrow */
.tp-hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 7px 20px;
  background: rgba(61,102,66,0.12);
  border: 1px solid rgba(61,102,66,0.3);
  border-radius: 40px;
  font-size: 10px;
  font-weight: 600;
  color: var(--sage);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 32px;
}

.tp-hero-eyebrow-dot {
  width: 5px; height: 5px;
  background: var(--meadow);
  border-radius: 50%;
  animation: blink 2.5s ease infinite;
  box-shadow: 0 0 8px var(--meadow);
}

@keyframes blink {
  0%,100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.3; transform: scale(0.6); }
}

.tp-start-area h2 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(52px, 8.5vw, 96px);
  font-weight: 400;
  line-height: 1.0;
  color: var(--text-primary);
  margin-bottom: 22px;
  letter-spacing: -2px;
}

.tp-start-area h2 em {
  font-style: italic;
  color: var(--meadow);
}

.tp-start-area > p {
  font-size: 16px;
  color: var(--text-secondary);
  max-width: 380px;
  margin: 0 auto 48px;
  font-weight: 300;
  line-height: 1.7;
}

/* Scrolling destinations ticker */
.tp-hero-ticker {
  overflow: hidden;
  margin-bottom: 52px;
  border-top: 1px solid var(--moss);
  border-bottom: 1px solid var(--moss);
  padding: 14px 0;
  position: relative;
}

.tp-hero-ticker::before,
.tp-hero-ticker::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 80px;
  z-index: 2;
}

.tp-hero-ticker::before {
  left: 0;
  background: linear-gradient(to right, var(--soil), transparent);
}

.tp-hero-ticker::after {
  right: 0;
  background: linear-gradient(to left, var(--soil), transparent);
}

.tp-hero-ticker-inner {
  display: flex;
  width: max-content;
  animation: ticker 30s linear infinite;
}

@keyframes ticker {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

.tp-hero-ticker-item {
  display: inline-flex;
  align-items: center;
  gap: 18px;
  padding: 0 28px;
  font-family: 'DM Serif Display', serif;
  font-size: 15px;
  font-style: italic;
  color: var(--text-muted);
  letter-spacing: 0.5px;
}

.tp-hero-ticker-sep {
  color: var(--amber);
  font-size: 10px;
  opacity: 0.7;
}

/* CTA Button */
.tp-start-btn {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  padding: 18px 56px;
  background: linear-gradient(135deg, var(--canopy) 0%, var(--fern) 100%);
  color: var(--dew);
  border: none;
  border-radius: 60px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 3.5px;
  text-transform: uppercase;
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  position: relative;
  overflow: hidden;
  transition: all 0.45s var(--ease-out);
  box-shadow:
    0 8px 32px rgba(46,74,50,0.45),
    0 2px 0 rgba(255,255,255,0.06) inset,
    0 -2px 0 rgba(0,0,0,0.2) inset;
  border: 1px solid var(--fern);
}

.tp-start-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--amber) 0%, var(--amber-light) 100%);
  opacity: 0;
  transition: opacity 0.4s;
}

.tp-start-btn:hover::before { opacity: 1; }

.tp-start-btn:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 50px rgba(46,74,50,0.5), 0 0 40px rgba(212,137,58,0.25);
}

.tp-start-btn span { position: relative; z-index: 1; }

/* Stats */
.tp-hero-stats {
  display: flex;
  justify-content: center;
  gap: 64px;
  margin-top: 72px;
  padding-top: 40px;
  border-top: 1px solid var(--moss);
}

.tp-hero-stat-num {
  font-family: 'DM Serif Display', serif;
  font-size: 34px;
  color: var(--dew);
  line-height: 1;
  margin-bottom: 5px;
  font-style: italic;
}

.tp-hero-stat-label {
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 2.5px;
  text-transform: uppercase;
  font-weight: 500;
}

/* Recent trips */
.tp-recent-trips { margin-top: 56px; }

.tp-recent-label {
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 16px;
  font-weight: 500;
}

.tp-recent-pills {
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
}

.tp-recent-pill {
  padding: 10px 22px;
  background: var(--bark);
  border: 1px solid var(--moss);
  border-radius: 40px;
  font-size: 13px;
  color: var(--text-secondary);
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  font-weight: 400;
  transition: all 0.3s var(--ease-out);
}

.tp-recent-pill:hover {
  background: var(--canopy);
  color: var(--dew);
  border-color: var(--fern);
  transform: translateY(-2px);
  box-shadow: 0 6px 24px rgba(46,74,50,0.35);
}

/* ════════════════════════════════
   WIZARD MODAL
   ════════════════════════════════ */
.tp-overlay {
  position: fixed;
  inset: 0;
  z-index: 500;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(16px) saturate(0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  animation: tpFadeIn 0.3s ease;
}

@keyframes tpFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.tp-modal {
  background: var(--bark);
  border-radius: 32px;
  padding: 52px 48px;
  width: 100%;
  max-width: 560px;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
  border: 1px solid var(--moss);
  box-shadow:
    0 48px 120px rgba(0,0,0,0.6),
    0 0 0 1px rgba(255,255,255,0.03) inset;
  animation: tpModalIn 0.5s var(--ease-spring);
}

@keyframes tpModalIn {
  from { opacity: 0; transform: scale(0.88) translateY(24px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.tp-modal-close {
  position: absolute;
  top: 20px; right: 20px;
  width: 36px; height: 36px;
  background: var(--moss-dark);
  border: 1px solid var(--moss);
  border-radius: 50%;
  color: var(--text-muted);
  font-size: 14px;
  cursor: pointer;
  transition: all 0.25s;
  display: flex; align-items: center; justify-content: center;
}

.tp-modal-close:hover {
  background: var(--terracotta);
  color: var(--cream);
  border-color: var(--terracotta);
  transform: rotate(90deg);
}

/* ── Step base ── */
.tp-step {
  animation: tpSlideUp 0.5s var(--ease-out);
}

@keyframes tpSlideUp {
  from { opacity: 0; transform: translateY(28px); }
  to { opacity: 1; transform: translateY(0); }
}

.tp-step-icon {
  font-size: 52px;
  margin-bottom: 20px;
  display: block;
  animation: iconPop 0.6s var(--ease-spring);
  filter: drop-shadow(0 8px 20px rgba(46,74,50,0.6));
}

@keyframes iconPop {
  from { transform: scale(0.5) rotate(-12deg); opacity: 0; }
  to { transform: scale(1) rotate(0); opacity: 1; }
}

.tp-step h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 38px;
  font-weight: 400;
  color: var(--dew);
  margin-bottom: 10px;
  line-height: 1.1;
  letter-spacing: -1px;
}

.tp-step > p {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 32px;
  font-weight: 300;
  line-height: 1.6;
}

/* Input */
.tp-input {
  width: 100%;
  padding: 18px 22px;
  background: var(--moss-dark);
  border: 1.5px solid var(--moss);
  border-radius: 16px;
  font-size: 20px;
  font-family: 'DM Serif Display', serif;
  font-style: italic;
  color: var(--dew);
  outline: none;
  margin-bottom: 20px;
  transition: all 0.35s var(--ease-out);
  letter-spacing: -0.3px;
}

.tp-input::placeholder { color: var(--text-faint); font-style: italic; }

.tp-input:focus {
  border-color: var(--fern);
  background: var(--moss-dark);
  box-shadow: 0 0 0 4px rgba(61,102,66,0.18), 0 8px 32px rgba(46,74,50,0.2);
  transform: translateY(-1px);
}

/* Primary button */
.tp-btn-primary {
  padding: 16px 40px;
  background: linear-gradient(135deg, var(--canopy), var(--fern));
  color: var(--dew);
  border: 1px solid var(--fern);
  border-radius: 50px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  transition: all 0.35s var(--ease-out);
  position: relative;
  overflow: hidden;
  box-shadow: 0 6px 24px rgba(46,74,50,0.35);
}

.tp-btn-primary::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--amber), var(--amber-light));
  opacity: 0;
  transition: opacity 0.35s;
}

.tp-btn-primary:not(:disabled):hover::after { opacity: 1; }

.tp-btn-primary:not(:disabled):hover {
  transform: translateY(-2px);
  box-shadow: 0 14px 40px rgba(46,74,50,0.45);
}

.tp-btn-primary span { position: relative; z-index: 1; }

.tp-btn-primary:disabled {
  background: var(--moss-dark);
  color: var(--text-faint);
  border-color: var(--moss);
  cursor: not-allowed;
  box-shadow: none;
}

/* ════════════════════════════════
   PREFERENCES GRID
   ════════════════════════════════ */
.tp-prefs-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 32px;
}

.tp-pref-card {
  padding: 20px 12px 16px;
  background: var(--moss-dark);
  border: 1.5px solid var(--moss);
  border-radius: 20px;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s var(--ease-spring);
  position: relative;
  overflow: hidden;
}

.tp-pref-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: var(--fern);
  transform: scaleX(0);
  transition: transform 0.3s var(--ease-out);
  transform-origin: center;
}

.tp-pref-card.selected::after { transform: scaleX(1); }

.tp-pref-card:hover {
  transform: translateY(-4px) scale(1.02);
  border-color: var(--fern);
}

.tp-pref-card.selected {
  transform: translateY(-4px) scale(1.04);
  box-shadow: 0 8px 28px rgba(0,0,0,0.4);
}

.tp-pref-check {
  position: absolute;
  top: 8px; right: 8px;
  width: 20px; height: 20px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px;
  color: var(--dew);
  transition: all 0.3s var(--ease-spring);
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
}

.tp-pref-icon {
  font-size: 28px;
  margin-bottom: 8px;
  display: block;
  transition: transform 0.35s var(--ease-spring);
  filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
}

.tp-pref-card:hover .tp-pref-icon,
.tp-pref-card.selected .tp-pref-icon {
  transform: scale(1.2) rotate(-6deg);
}

.tp-pref-label {
  font-size: 11px;
  font-weight: 500;
  color: var(--text-muted);
  letter-spacing: 0.3px;
  transition: color 0.25s;
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

/* ════════════════════════════════
   DAYS SELECTOR
   ════════════════════════════════ */
.tp-days-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 36px;
  margin-bottom: 24px;
  padding: 36px 28px;
  background: var(--moss-dark);
  border-radius: 28px;
  border: 1.5px solid var(--moss);
  position: relative;
  overflow: hidden;
}

.tp-days-picker::before {
  content: '';
  position: absolute;
  top: -60px; left: 50%;
  transform: translateX(-50%);
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(46,74,50,0.4) 0%, transparent 70%);
  pointer-events: none;
}

.tp-days-btn {
  width: 54px; height: 54px;
  background: var(--bark);
  border: 1.5px solid var(--moss);
  border-radius: 18px;
  color: var(--text-secondary);
  font-size: 22px;
  cursor: pointer;
  transition: all 0.3s var(--ease-spring);
  display: flex; align-items: center; justify-content: center;
  z-index: 1;
}

.tp-days-btn:hover {
  background: var(--canopy);
  color: var(--dew);
  border-color: var(--fern);
  transform: scale(1.12);
  box-shadow: 0 6px 20px rgba(46,74,50,0.4);
}

.tp-days-num {
  font-family: 'DM Serif Display', serif;
  font-size: 100px;
  color: var(--dew);
  line-height: 0.9;
  letter-spacing: -4px;
  z-index: 1;
  text-shadow: 0 8px 40px rgba(0,0,0,0.4);
}

.tp-days-label {
  font-size: 10px;
  color: var(--sage);
  letter-spacing: 4px;
  text-transform: uppercase;
  text-align: center;
  margin-top: 6px;
  font-weight: 500;
}

/* Calendar strip */
.tp-days-calendar {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding: 4px 0 12px;
  scrollbar-width: none;
  margin-bottom: 16px;
}

.tp-days-calendar::-webkit-scrollbar { display: none; }

.tp-cal-day {
  flex-shrink: 0;
  width: 52px;
  padding: 14px 4px;
  background: var(--moss-dark);
  border: 1.5px solid var(--moss);
  border-radius: 16px;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s var(--ease-spring);
}

.tp-cal-day:hover {
  border-color: var(--fern);
  transform: translateY(-3px);
  background: var(--canopy);
}

.tp-cal-day.active {
  background: linear-gradient(160deg, var(--fern), var(--canopy));
  border-color: var(--fern);
  transform: translateY(-5px);
  box-shadow: 0 10px 28px rgba(46,74,50,0.5);
}

.tp-cal-day-num {
  font-family: 'DM Serif Display', serif;
  font-size: 20px;
  color: var(--text-secondary);
  line-height: 1;
  font-style: italic;
  transition: color 0.2s;
}

.tp-cal-day:hover .tp-cal-day-num,
.tp-cal-day.active .tp-cal-day-num { color: var(--dew); }

.tp-cal-day-label {
  font-size: 9px;
  color: var(--text-faint);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-top: 3px;
  font-weight: 500;
  transition: color 0.2s;
}

.tp-cal-day.active .tp-cal-day-label { color: var(--mist); }

/* Quick presets */
.tp-quick-days {
  display: flex;
  gap: 0;
  background: var(--moss-dark);
  border: 1.5px solid var(--moss);
  border-radius: 16px;
  padding: 4px;
  margin-bottom: 24px;
}

.tp-quick-day {
  flex: 1;
  padding: 10px 4px;
  background: none;
  border: none;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-muted);
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  letter-spacing: 0.5px;
  transition: all 0.25s var(--ease-spring);
}

.tp-quick-day:hover { color: var(--meadow); }

.tp-quick-day.active {
  background: var(--canopy);
  color: var(--dew);
  box-shadow: 0 3px 14px rgba(46,74,50,0.4);
}

/* ════════════════════════════════
   LOADING SCREEN
   ════════════════════════════════ */
.tp-loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120px 0;
  animation: tpSlideUp 0.5s ease;
}

.tp-loading-globe {
  width: 110px; height: 110px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, var(--canopy), var(--soil) 75%);
  border: 1px solid var(--fern);
  display: flex; align-items: center; justify-content: center;
  font-size: 52px;
  margin-bottom: 36px;
  position: relative;
  animation: globeBreath 3s ease infinite;
  box-shadow:
    0 0 0 0 rgba(61,102,66,0.4),
    0 20px 60px rgba(0,0,0,0.4);
}

@keyframes globeBreath {
  0%,100% { box-shadow: 0 0 0 0 rgba(61,102,66,0.4), 0 20px 60px rgba(0,0,0,0.4); }
  50% { box-shadow: 0 0 0 24px rgba(61,102,66,0), 0 20px 60px rgba(0,0,0,0.4); }
}

.tp-loading-screen h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 28px;
  color: var(--dew);
  margin-bottom: 10px;
  font-style: italic;
}

.tp-loading-screen p {
  color: var(--text-muted);
  font-size: 14px;
  margin-bottom: 36px;
  font-weight: 300;
}

.tp-loading-bar-wrap {
  width: 220px; height: 2px;
  background: var(--moss);
  border-radius: 2px;
  overflow: hidden;
}

.tp-loading-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--fern), var(--meadow), var(--amber));
  border-radius: 2px;
  animation: loadBar 2.8s var(--ease-out) infinite;
}

@keyframes loadBar {
  0% { width: 0; }
  60% { width: 100%; }
  61% { width: 100%; transform: translateX(0); }
  100% { width: 100%; transform: translateX(110%); }
}

/* ════════════════════════════════
   RESULT HEADER
   ════════════════════════════════ */
.tp-result-header {
  padding: 64px 0 40px;
  text-align: center;
}

.tp-result-prefs {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.tp-result-pref-badge {
  padding: 5px 14px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.3px;
}

.tp-result-header h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(44px, 7vw, 80px);
  font-weight: 400;
  font-style: italic;
  color: var(--dew);
  letter-spacing: -2px;
  line-height: 1;
  margin-bottom: 14px;
}

.tp-result-meta {
  font-size: 11px;
  color: var(--text-muted);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 28px;
  font-weight: 500;
}

.tp-result-actions {
  display: flex;
  gap: 10px;
  justify-content: center;
}

.tp-action-btn {
  padding: 10px 24px;
  border-radius: 40px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  transition: all 0.3s;
  border: 1.5px solid;
}

.tp-action-btn.save {
  background: rgba(61,102,66,0.15);
  border-color: var(--fern);
  color: var(--meadow);
}

.tp-action-btn.save:hover {
  background: var(--canopy);
  color: var(--dew);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(46,74,50,0.4);
}

.tp-action-btn.reset {
  background: none;
  border-color: var(--moss);
  color: var(--text-muted);
}

.tp-action-btn.reset:hover {
  background: var(--bark);
  color: var(--dew);
  border-color: var(--text-muted);
}

/* ════════════════════════════════
   TABS
   ════════════════════════════════ */
.tp-tabs {
  display: flex;
  gap: 0;
  background: var(--bark);
  border: 1.5px solid var(--moss);
  border-radius: 20px;
  padding: 4px;
  margin-bottom: 28px;
}

.tp-tab {
  flex: 1;
  padding: 14px;
  background: none;
  border: none;
  border-radius: 16px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-muted);
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  letter-spacing: 0.5px;
  transition: all 0.3s var(--ease-spring);
}

.tp-tab:hover { color: var(--dew); }

.tp-tab.active {
  background: var(--canopy);
  color: var(--dew);
  box-shadow: 0 2px 16px rgba(46,74,50,0.4);
}

/* ════════════════════════════════
   MAP
   ════════════════════════════════ */
.tp-map-day-selector {
  display: flex;
  gap: 8px;
  padding: 0 0 16px;
  overflow-x: auto;
  scrollbar-width: none;
}

.tp-map-day-selector::-webkit-scrollbar { display: none; }

.tp-map-day-btn {
  flex-shrink: 0;
  padding: 8px 20px;
  background: var(--bark);
  border: 1.5px solid var(--moss);
  border-radius: 40px;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-muted);
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  transition: all 0.25s var(--ease-spring);
}

.tp-map-day-btn:hover { border-color: var(--fern); color: var(--dew); }

.tp-map-day-btn.active {
  background: var(--canopy);
  color: var(--dew);
  border-color: var(--fern);
  box-shadow: 0 4px 16px rgba(46,74,50,0.4);
}

.tp-map-wrap {
  height: 440px;
  border-radius: 24px;
  overflow: hidden;
  position: relative;
  border: 1.5px solid var(--moss);
  box-shadow: 0 8px 48px rgba(0,0,0,0.4);
}

/* Leaflet dark tint */
.tp-map-wrap .leaflet-container {
  filter: saturate(0.7) brightness(0.8) hue-rotate(10deg);
}

.leaflet-popup-content-wrapper {
  background: var(--bark) !important;
  border-radius: 16px !important;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important;
  border: 1px solid var(--moss) !important;
  color: var(--text-primary) !important;
}

.leaflet-popup-tip {
  background: var(--bark) !important;
}

.tp-map-legend {
  position: absolute;
  top: 16px; left: 16px; right: 16px;
  background: rgba(20, 26, 21, 0.92);
  backdrop-filter: blur(20px);
  border-radius: 18px;
  padding: 16px 20px;
  border: 1px solid var(--moss);
  box-shadow: 0 4px 24px rgba(0,0,0,0.4);
}

.tp-map-legend-title {
  font-size: 10px;
  color: var(--sage);
  letter-spacing: 2.5px;
  text-transform: uppercase;
  font-weight: 600;
  margin-bottom: 10px;
}

.tp-map-legend-places {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.tp-map-legend-pill {
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 500;
}

/* ════════════════════════════════
   DAY CARDS
   ════════════════════════════════ */
.tp-day-card {
  margin-bottom: 10px;
  border-radius: 24px;
  background: var(--bark);
  border: 1.5px solid var(--moss);
  overflow: hidden;
  transition: all 0.3s var(--ease-out);
  animation: tpSlideUp 0.5s var(--ease-out) both;
}

.tp-day-card:hover {
  border-color: var(--fern);
  box-shadow: 0 8px 40px rgba(0,0,0,0.3), 0 0 0 1px rgba(61,102,66,0.1);
}

.tp-day-header {
  padding: 22px 28px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background 0.25s;
}

.tp-day-header.expanded {
  background: rgba(46,74,50,0.15);
  border-bottom: 1px solid var(--moss);
}

.tp-day-header-left {
  display: flex;
  align-items: center;
  gap: 18px;
}

.tp-day-num {
  width: 50px; height: 50px;
  background: var(--canopy);
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'DM Serif Display', serif;
  font-size: 22px;
  font-style: italic;
  color: var(--dew);
  flex-shrink: 0;
  border: 1px solid var(--fern);
  box-shadow: 0 4px 16px rgba(46,74,50,0.3);
  transition: all 0.3s var(--ease-spring);
}

.tp-day-header:hover .tp-day-num,
.tp-day-header.expanded .tp-day-num {
  background: linear-gradient(135deg, var(--amber), var(--amber-light));
  border-color: var(--amber);
  box-shadow: 0 6px 20px rgba(212,137,58,0.4);
  transform: rotate(-4deg);
}

.tp-day-title {
  font-family: 'DM Serif Display', serif;
  font-size: 22px;
  font-style: italic;
  color: var(--dew);
  letter-spacing: -0.5px;
  margin-bottom: 3px;
}

.tp-day-subtitle {
  font-size: 12px;
  color: var(--text-muted);
  letter-spacing: 0.3px;
  font-weight: 300;
}

.tp-day-chevron {
  font-size: 18px;
  color: var(--text-faint);
  transition: transform 0.35s var(--ease-out), color 0.25s;
}

.tp-day-chevron.open {
  transform: rotate(180deg);
  color: var(--sage);
}

/* Activities */
.tp-activities {
  padding: 12px 28px 28px 28px;
  position: relative;
}

.tp-timeline-line {
  position: absolute;
  left: 52px;
  top: 20px;
  bottom: 28px;
  width: 1px;
  background: linear-gradient(to bottom, var(--moss) 0%, transparent 100%);
}

.tp-activity {
  display: flex;
  gap: 20px;
  margin-bottom: 24px;
  animation: tpSlideUp 0.45s var(--ease-out) both;
}

.tp-activity:last-child { margin-bottom: 0; }

.tp-activity-icon {
  width: 44px; height: 44px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
  margin-top: 2px;
  transition: transform 0.3s var(--ease-spring);
  position: relative;
  z-index: 1;
  border: 1.5px solid;
}

.tp-activity:hover .tp-activity-icon {
  transform: scale(1.12) rotate(-5deg);
}

.tp-activity-content { flex: 1; }

.tp-activity-time {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
}

.tp-activity-title {
  font-family: 'DM Serif Display', serif;
  font-size: 20px;
  font-style: italic;
  color: var(--dew);
  letter-spacing: -0.3px;
}

.tp-activity-place {
  font-size: 12px;
  color: var(--text-muted);
  margin-bottom: 6px;
  margin-top: 2px;
  font-weight: 300;
}

.tp-activity-desc {
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.7;
  font-weight: 300;
  margin: 0;
}

.tp-activity-tip {
  margin-top: 10px;
  padding: 10px 14px;
  background: rgba(46,74,50,0.18);
  border: 1px solid rgba(61,102,66,0.3);
  border-left: 3px solid var(--sage);
  border-radius: 0 10px 10px 0;
  font-size: 12px;
  color: var(--sage);
  font-weight: 400;
  line-height: 1.5;
}

/* ════════════════════════════════
   SAVED TRIPS
   ════════════════════════════════ */
.tp-saved-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 64px 0 40px;
}

.tp-saved-header h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 40px;
  font-style: italic;
  color: var(--dew);
  letter-spacing: -1px;
}

.tp-saved-empty {
  text-align: center;
  padding: 80px 20px;
  color: var(--text-muted);
  font-size: 15px;
  font-weight: 300;
}

.tp-saved-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22px 28px;
  background: var(--bark);
  border: 1.5px solid var(--moss);
  border-radius: 20px;
  margin-bottom: 10px;
  cursor: pointer;
  transition: all 0.3s var(--ease-out);
  animation: tpSlideUp 0.4s var(--ease-out) both;
}

.tp-saved-card:hover {
  border-color: var(--fern);
  box-shadow: 0 6px 32px rgba(0,0,0,0.3);
  transform: translateX(6px);
}

.tp-saved-card-dest {
  font-family: 'DM Serif Display', serif;
  font-size: 24px;
  font-style: italic;
  color: var(--dew);
  margin-bottom: 5px;
  letter-spacing: -0.5px;
}

.tp-saved-card-meta {
  font-size: 12px;
  color: var(--text-muted);
  font-weight: 300;
}

.tp-saved-card-delete {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 18px;
  background: none;
  border: 1px solid var(--moss);
  border-radius: 30px;
  color: var(--text-muted);
  font-size: 12px;
  cursor: pointer;
  font-family: 'Jost', sans-serif;
  transition: all 0.25s;
  flex-shrink: 0;
}

.tp-saved-card-delete:hover {
  background: rgba(196,98,58,0.15);
  color: var(--terracotta);
  border-color: rgba(196,98,58,0.4);
}

/* Spinner */
.tp-spinner {
  display: inline-block;
  width: 18px; height: 18px;
  border: 2px solid var(--moss);
  border-top-color: var(--meadow);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* Leaflet marker */
.tp-marker-custom { background: none !important; border: none !important; }

/* Responsive */
@media (max-width: 640px) {
  .tp-nav { padding: 0 16px; }
  .tp-content { padding-left: 16px; padding-right: 16px; }
  .tp-modal { padding: 36px 22px; border-radius: 24px; }
  .tp-prefs-grid { grid-template-columns: repeat(3, 1fr); gap: 7px; }
  .tp-hero-stats { gap: 32px; }
  .tp-start-area h2 { font-size: 46px; letter-spacing: -1px; }
  .tp-nav-links .tp-nav-link:not(.active) { display: none; }
}